# ── Secrets (file paths) ─────────────────────────────────────────────
HF_TOKEN_FILE=~/.secrets/hf_token.txt
VLLM_API_KEY_FILE=~/.secrets/vllm_api_key.txt
NGINX_TLS_CERT_FILE=~/.secrets/nginx-certs/tls.crt
NGINX_TLS_KEY_FILE=~/.secrets/nginx-certs/tls.key

# ── Nginx ports ──────────────────────────────────────────────────────
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# ── Shared HF model cache volume ────────────────────────────────────
HF_CACHE_VOLUME_NAME=vllm-hf-home

# ── Container UIDs/GIDs ─────────────────────────────────────────────
LMROUTER_UID=10001
LMROUTER_GID=10001
VLLM_UID=10001
VLLM_GID=10001
NGINX_UID=101
NGINX_GID=101
