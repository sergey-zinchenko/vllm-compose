FROM vllm/vllm-openai:v0.17.0

USER root

ARG APP_UID=10001
ARG APP_GID=10001

COPY docker-entrypoint-vllm-secrets.sh /usr/local/bin/docker-entrypoint-vllm-secrets.sh

RUN set -eux; \
    if ! getent group vllmuser >/dev/null 2>&1; then \
        groupadd --gid "$APP_GID" vllmuser; \
    fi; \
    if ! id -u vllmuser >/dev/null 2>&1; then \
        useradd --uid "$APP_UID" --gid "$APP_GID" --create-home --shell /bin/sh vllmuser; \
    fi; \
    mkdir -p /hf_home; \
    chown -R "$APP_UID":"$APP_GID" /hf_home; \
    chmod 755 /usr/local/bin/docker-entrypoint-vllm-secrets.sh

WORKDIR /home/vllmuser
USER vllmuser

ENTRYPOINT ["/usr/local/bin/docker-entrypoint-vllm-secrets.sh"]